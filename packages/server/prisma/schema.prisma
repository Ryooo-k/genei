// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CardType {
  unit
  spell
  field
  art
}

enum GameResult {
  win
  lose
  draw
}

model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  password    String
  rating      Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  decks       Deck[]
  gamePlayers GamePlayer[]
}

model GameMode {
  id        String   @id @default(cuid())
  name      String
  modeType  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  games     Game[]
}

model Hero {
  id        String   @id @default(cuid())
  name      String
  maxHp     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  decks     Deck[]
}

model Card {
  id        String     @id @default(cuid())
  name      String
  cost      Int
  attack    Int?
  hp        Int?
  cardType  CardType
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deckCards DeckCard[]
}

model Deck {
  id          String       @id @default(cuid())
  name        String
  userId      String
  heroId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  hero        Hero         @relation(fields: [heroId], references: [id], onDelete: Cascade)
  deckCards   DeckCard[]
  gamePlayers GamePlayer[]
}

model DeckCard {
  id        String   @id @default(cuid())
  deckId    String
  cardId    String
  createdAt DateTime @default(now())
  deck      Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Game {
  id          String       @id @default(cuid())
  gameModeId  String
  status      String
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  gameMode    GameMode     @relation(fields: [gameModeId], references: [id], onDelete: Cascade)
  gamePlayers GamePlayer[]
}

model GamePlayer {
  id           String     @id @default(cuid())
  gameId       String
  userId       String
  deckId       String
  result       GameResult?
  ratingBefore Int
  ratingAfter  Int
  createdAt    DateTime   @default(now())
  game         Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck         Deck       @relation(fields: [deckId], references: [id], onDelete: Cascade)
}
